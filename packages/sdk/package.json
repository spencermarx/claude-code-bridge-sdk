{
  "name": "claude-code-bridge-sdk",
  "version": "0.0.1",
  "description": "Ergonomic TypeScript SDK for building apps on top of Claude Code. Sessions, pools, AskUserQuestion bridge, and on-disk session inspection over @anthropic-ai/claude-agent-sdk.",
  "keywords": ["claude", "claude-code", "anthropic", "agent", "sdk", "ai", "llm", "typescript"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spencermarx/claude-code-bridge-sdk.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/spencermarx/claude-code-bridge-sdk",
  "bugs": {
    "url": "https://github.com/spencermarx/claude-code-bridge-sdk/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18.17"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "vitest run && vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "e2e:doctor": "node ./scripts/e2e-doctor.mjs",
    "lint": "biome check src test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0"
  },
  "peerDependencies": {
    "zod": "^3.23.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "claude-code-bridge-tsconfig": "workspace:*",
    "@types/node": "^22.9.0",
    "expect-type": "^1.1.0",
    "tsdown": "^0.9.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
